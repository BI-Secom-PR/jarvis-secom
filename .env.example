# n8n webhook URL (server-side only — never exposed to the browser)
# Set this in Vercel: Settings → Environment Variables
WEBHOOK_URL=https://your-n8n-instance.com/webhook/YOUR-WORKFLOW-ID/chat

# Vercel Blob — required for file uploads > 4.5MB on Vercel
# Generate at: vercel.com → Storage → Blob → Create Store → get token
# On-prem: leave unset (files go via multipart directly)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxx

# Optional: max request body size accepted by Next.js routes and Server Actions
# Increase if verification uploads exceed the default (e.g. 300mb)
MAX_UPLOAD_BODY_SIZE=200mb

    "@simplewebauthn/server": "^13.3.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@vercel/blob": "^2.4.0",
    "ai": "^6.0.116",
    "bcryptjs": "^3.0.3",
    "d3-geo": "^3.1.1",
    "dompurify": "^3.4.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "jose": "^6.2.3",
    "mysql2": "^3.19.1",
    "nanoid": "^5.1.11",
    "next": "16.2.6",
    "ollama": "^0.6.3",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-is": "^19.2.7",
    "recharts": "^3.8.0",
    "resend": "^6.12.4",
    "zod": "^4.3.6"
  },
  "overrides": {
    "protobufjs": "~7.5.8",
    "esbuild": ">=0.28.1",

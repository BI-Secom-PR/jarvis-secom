{
  "name": "jarvis-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "db:push": "bun --env-file=.env.local node_modules/.bin/drizzle-kit push --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun --env-file=.env.local lib/db/migrate.ts",
    "db:seed": "bun --env-file=.env.local lib/db/seed.ts",
    "tunnel": "bash scripts/tunnel-pg.sh",
    "tunnel:close": "bash scripts/tunnel-pg.sh close",
    "tunnel:status": "bash scripts/tunnel-pg.sh status"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@google/genai": "^1.45.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "ai": "^6.0.116",
    "bcryptjs": "^3.0.3",
    "dompurify": "^3.3.3",
    "drizzle-orm": "^0.45.1",
    "mysql2": "^3.19.1",
    "next": "16.1.6",
    "ollama": "^0.6.3",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "resend": "^6.9.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "^2.1.76",
    "@tailwindcss/postcss": "^4",
    "@types/dom-speech-recognition": "^0.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
